#!/usr/bin/env sh
set -eu

warn() {
    printf 'xbbg-mcp: %s\n' "$1" >&2
}

die() {
    warn "$1"
    exit 1
}

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

choose_python() {
    if command_exists python3; then
        printf '%s\n' python3
        return 0
    fi

    if command_exists python; then
        printf '%s\n' python
        return 0
    fi

    return 1
}

script_dir() {
    CDPATH= cd -- "$(dirname -- "$0")" && pwd
}

contains_blpapi_lib() {
    dir=$1
    [ -d "$dir" ] || return 1

    for name in \
        libblpapi3.dylib \
        libblpapi3.so \
        libblpapi3_64.so \
        blpapi3_64.dll \
        blpapi3_32.dll
    do
        if [ -f "$dir/$name" ]; then
            return 0
        fi
    done

    return 1
}

resolve_sdk_root_layout() {
    sdk_root=$1
    [ -d "$sdk_root" ] || return 1

    if contains_blpapi_lib "$sdk_root"; then
        printf '%s\n' "$sdk_root"
        return 0
    fi

    os_name=$(uname -s 2>/dev/null || printf 'unknown')
    case "$os_name" in
        Darwin)
            for candidate in "$sdk_root/Darwin" "$sdk_root/lib" "$sdk_root/lib64"; do
                if contains_blpapi_lib "$candidate"; then
                    printf '%s\n' "$candidate"
                    return 0
                fi
            done
            ;;
        Linux)
            for candidate in "$sdk_root/Linux" "$sdk_root/lib64" "$sdk_root/lib"; do
                if contains_blpapi_lib "$candidate"; then
                    printf '%s\n' "$candidate"
                    return 0
                fi
            done
            ;;
        MINGW*|MSYS*|CYGWIN*)
            for candidate in "$sdk_root/bin" "$sdk_root/lib"; do
                if contains_blpapi_lib "$candidate"; then
                    printf '%s\n' "$candidate"
                    return 0
                fi
            done
            ;;
        *)
            for candidate in "$sdk_root/lib" "$sdk_root/lib64"; do
                if contains_blpapi_lib "$candidate"; then
                    printf '%s\n' "$candidate"
                    return 0
                fi
            done
            ;;
    esac

    latest_version_dir=$(find_latest_version_dir "$sdk_root") || latest_version_dir=
    if [ -n "$latest_version_dir" ]; then
        resolve_sdk_root_layout "$latest_version_dir" && return 0
    fi

    return 1
}

find_latest_version_dir() {
    root=$1
    [ -d "$root" ] || return 1

    py=$(choose_python) || return 1
    ROOT="$root" "$py" - <<'PY'
import os
from pathlib import Path
import re

root = Path(os.environ["ROOT"])
pattern = re.compile(r"\d+\.\d+\.\d+(?:\.\d+)?$")
candidates = [path for path in root.iterdir() if path.is_dir() and pattern.fullmatch(path.name)]
if not candidates:
    raise SystemExit(1)

def key(path: Path) -> tuple[int, ...]:
    parts = [int(part) for part in path.name.split(".")]
    while len(parts) < 4:
        parts.append(0)
    return tuple(parts)

print(max(candidates, key=key))
PY
}

find_python_blpapi_dir() {
    py=$(choose_python) || return 1
    "$py" - <<'PY'
from __future__ import annotations

from pathlib import Path

try:
    import blpapi  # type: ignore
except Exception as exc:
    raise SystemExit(1) from exc

module_path = getattr(blpapi, "__file__", None)
if not module_path:
    raise SystemExit(1)

path = Path(module_path).resolve().parent
for candidate in (path, path / "lib"):
    if any((candidate / name).is_file() for name in (
        "libblpapi3.dylib",
        "libblpapi3.so",
        "libblpapi3_64.so",
        "blpapi3_64.dll",
        "blpapi3_32.dll",
    )):
        print(candidate)
        raise SystemExit(0)

raise SystemExit(1)
PY
}

find_vendored_sdk_dir() {
    base_dir=$1
    vendor_root="$base_dir/vendor/blpapi-sdk"
    [ -d "$vendor_root" ] || return 1

    latest_version_dir=$(find_latest_version_dir "$vendor_root") || return 1
    resolve_sdk_root_layout "$latest_version_dir"
}

find_runtime_lib_dir() {
    if [ "${XBBG_MCP_LIB_DIR:-}" ] && contains_blpapi_lib "$XBBG_MCP_LIB_DIR"; then
        printf '%s\n' "$XBBG_MCP_LIB_DIR"
        return 0
    fi

    if [ "${BLPAPI_LIB_DIR:-}" ] && contains_blpapi_lib "$BLPAPI_LIB_DIR"; then
        printf '%s\n' "$BLPAPI_LIB_DIR"
        return 0
    fi

    if [ "${BLPAPI_ROOT:-}" ]; then
        lib_dir=$(resolve_sdk_root_layout "$BLPAPI_ROOT") || lib_dir=
        if [ -n "$lib_dir" ]; then
            printf '%s\n' "$lib_dir"
            return 0
        fi
    fi

    script_home=$(script_dir)
    repo_root=$(CDPATH= cd -- "$script_home/.." 2>/dev/null && pwd || true)
    if [ -n "$repo_root" ]; then
        lib_dir=$(find_vendored_sdk_dir "$repo_root") || lib_dir=
        if [ -n "$lib_dir" ]; then
            printf '%s\n' "$lib_dir"
            return 0
        fi
    fi

    lib_dir=$(find_python_blpapi_dir) || lib_dir=
    if [ -n "$lib_dir" ]; then
        printf '%s\n' "$lib_dir"
        return 0
    fi

    return 1
}

find_real_binary() {
    if [ "${XBBG_MCP_REAL_BIN:-}" ] && [ -x "$XBBG_MCP_REAL_BIN" ]; then
        printf '%s\n' "$XBBG_MCP_REAL_BIN"
        return 0
    fi

    home=$(script_dir)
    for candidate in \
        "$home/xbbg-mcp-real" \
        "$home/.xbbg-mcp-real" \
        "$home/../share/xbbg-mcp/bin/xbbg-mcp-real" \
        "$home/../target/release/xbbg-mcp" \
        "$home/../target/debug/xbbg-mcp"
    do
        if [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

append_loader_path() {
    lib_dir=$1
    os_name=$(uname -s 2>/dev/null || printf 'unknown')
    case "$os_name" in
        Darwin)
            export DYLD_LIBRARY_PATH="$lib_dir${DYLD_LIBRARY_PATH:+:$DYLD_LIBRARY_PATH}"
            ;;
        Linux)
            export LD_LIBRARY_PATH="$lib_dir${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
            ;;
        MINGW*|MSYS*|CYGWIN*)
            export PATH="$lib_dir${PATH:+:$PATH}"
            ;;
        *)
            export LD_LIBRARY_PATH="$lib_dir${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
            ;;
    esac
}

REAL_BIN=$(find_real_binary) || die "could not locate the real xbbg-mcp binary. Reinstall it or set XBBG_MCP_REAL_BIN."
LIB_DIR=$(find_runtime_lib_dir) || die "could not locate the Bloomberg runtime library. Set XBBG_MCP_LIB_DIR, BLPAPI_LIB_DIR, or BLPAPI_ROOT, or install Bloomberg's blpapi package."

append_loader_path "$LIB_DIR"
exec "$REAL_BIN" "$@"
