{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "es2023": true,
    "node": true,
    "vitest": true
  },
  "plugins": ["oxc", "typescript", "unicorn", "import", "node", "promise", "vitest", "jsdoc"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "error",
    "perf": "error",
    "style": "error",
    "restriction": "error",
    "nursery": "error"
  },
  "options": {
    "denyWarnings": true,
    "reportUnusedDisableDirectives": "error",
    "typeAware": true,
    "typeCheck": true
  },
  "ignorePatterns": ["dist/**", "node_modules/**", "packages/*/napi_xbbg.node"],
  "rules": {
    "eslint/func-style": "off",
    "eslint/id-length": "off",
    "eslint/max-lines": "off",
    "eslint/max-lines-per-function": "off",
    "eslint/max-params": "off",
    "eslint/max-statements": "off",
    "eslint/no-await-in-loop": "off",
    "eslint/class-methods-use-this": "off",
    "eslint/complexity": "off",
    "eslint/curly": "off",
    "eslint/default-case": "off",
    "eslint/init-declarations": "off",
    "eslint/max-classes-per-file": "off",
    "eslint/new-cap": "off",
    "eslint/no-console": "off",
    "eslint/no-magic-numbers": "off",
    "eslint/no-ternary": "off",
    "eslint/no-undefined": "off",
    "eslint/no-continue": "off",
    "eslint/no-duplicate-imports": "off",
    "eslint/no-empty-function": "off",
    "eslint/no-inline-comments": "off",
    "eslint/no-negated-condition": "off",
    "eslint/no-nested-ternary": "off",
    "eslint/no-throw-literal": "off",
    "eslint/no-use-before-define": "off",
    "eslint/no-useless-assignment": "off",
    "eslint/no-void": "off",
    "eslint/no-template-curly-in-string": "off",
    "eslint/no-undef": "off",
    "eslint/no-unused-expressions": "off",
    "eslint/preserve-caught-error": "off",
    "eslint/prefer-destructuring": "off",
    "eslint/require-await": "off",
    "eslint/sort-keys": "off",
    "eslint/sort-imports": "off",
    "eslint-plugin-import/no-anonymous-default-export": "off",
    "eslint-plugin-import/no-default-export": "off",
    "eslint-plugin-import/no-namespace": "off",
    "eslint-plugin-import/prefer-default-export": "off",
    "eslint-plugin-import/exports-last": "off",
    "eslint-plugin-import/group-exports": "off",
    "eslint-plugin-import/no-commonjs": "off",
    "eslint-plugin-import/no-named-export": "off",
    "eslint-plugin-import/no-nodejs-modules": "off",
    "eslint-plugin-import/no-relative-parent-imports": "off",
    "eslint-plugin-import/unambiguous": "off",
    "eslint-plugin-jest/expect-expect": "off",
    "eslint-plugin-jest/max-expects": "off",
    "eslint-plugin-jest/no-conditional-in-test": "off",
    "eslint-plugin-jest/no-done-callback": "off",
    "eslint-plugin-jest/prefer-ending-with-an-expect": "off",
    "eslint-plugin-jest/prefer-expect-assertions": "off",
    "eslint-plugin-jest/require-hook": "off",
    "eslint-plugin-jest/no-hooks": "off",
    "eslint-plugin-jest/prefer-importing-jest-globals": "off",
    "eslint-plugin-jest/valid-title": "off",
    "eslint-plugin-jsdoc/require-param": "off",
    "eslint-plugin-jsdoc/require-returns": "off",
    "eslint-plugin-node/global-require": "off",
    "eslint-plugin-node/no-process-env": "off",
    "eslint-plugin-promise/avoid-new": "off",
    "eslint-plugin-promise/prefer-await-to-callbacks": "off",
    "eslint-plugin-promise/prefer-await-to-then": "off",
    "eslint-plugin-unicorn/catch-error-name": "off",
    "eslint-plugin-unicorn/custom-error-definition": "off",
    "eslint-plugin-unicorn/filename-case": "off",
    "eslint-plugin-unicorn/no-array-callback-reference": "off",
    "eslint-plugin-unicorn/no-await-expression-member": "off",
    "eslint-plugin-unicorn/no-immediate-mutation": "off",
    "eslint-plugin-unicorn/no-nested-ternary": "off",
    "eslint-plugin-unicorn/no-process-exit": "off",
    "eslint-plugin-unicorn/no-null": "off",
    "eslint-plugin-unicorn/no-useless-undefined": "off",
    "eslint-plugin-unicorn/no-zero-fractions": "off",
    "eslint-plugin-unicorn/number-literal-case": "off",
    "eslint-plugin-unicorn/prefer-native-coercion-functions": "off",
    "eslint-plugin-unicorn/numeric-separators-style": "off",
    "eslint-plugin-unicorn/prefer-string-replace-all": "off",
    "eslint-plugin-unicorn/prefer-top-level-await": "off",
    "eslint-plugin-unicorn/prefer-import-meta-properties": "off",
    "eslint-plugin-unicorn/no-useless-promise-resolve-reject": "off",
    "eslint-plugin-unicorn/prefer-module": "off",
    "eslint-plugin-unicorn/switch-case-braces": "off",
    "eslint-plugin-vitest/expect-expect": "off",
    "eslint-plugin-vitest/max-expects": "off",
    "eslint-plugin-vitest/no-conditional-in-test": "off",
    "eslint-plugin-vitest/prefer-expect-assertions": "off",
    "eslint-plugin-vitest/require-hook": "off",
    "eslint-plugin-vitest/require-test-timeout": "off",
    "eslint-plugin-vitest/no-hooks": "off",
    "eslint-plugin-vitest/no-importing-vitest-globals": "off",
    "eslint-plugin-vitest/prefer-expect-type-of": "off",
    "eslint-plugin-vitest/prefer-importing-vitest-globals": "off",
    "eslint-plugin-vitest/prefer-strict-boolean-matchers": "off",
    "eslint-plugin-vitest/valid-title": "off",
    "oxc/no-async-await": "off",
    "oxc/no-optional-chaining": "off",
    "oxc/no-rest-spread-properties": "off",
    "typescript/consistent-type-imports": [
      "error",
      {
        "fixStyle": "inline-type-imports",
        "prefer": "type-imports"
      }
    ],
    "typescript/prefer-readonly-parameter-types": "off",
    "typescript/require-await": "off",
    "typescript/explicit-function-return-type": "off",
    "typescript/explicit-member-accessibility": "off",
    "typescript/no-require-imports": "off",
    "typescript/parameter-properties": "off",
    "typescript/no-unnecessary-condition": "off",
    "typescript/prefer-for-of": "off",
    "typescript/prefer-promise-reject-errors": "off",
    "typescript/return-await": "off",
    "typescript/restrict-template-expressions": [
      "error",
      {
        "allowNumber": true
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/*.js", "**/*.cjs", "**/*.mjs"],
      "rules": {
        "typescript/no-explicit-any": "off",
        "typescript/no-unsafe-argument": "off",
        "typescript/no-unsafe-assignment": "off",
        "typescript/no-unsafe-call": "off",
        "typescript/no-unsafe-member-access": "off",
        "typescript/no-unsafe-return": "off",
        "typescript/no-unsafe-type-assertion": "off",
        "typescript/strict-boolean-expressions": "off",
        "typescript/restrict-template-expressions": "off",
        "typescript/use-unknown-in-catch-callback-variable": "off"
      }
    },
    {
      "files": ["test/**/*.ts"],
      "rules": {
        "typescript/no-explicit-any": "off",
        "typescript/no-non-null-assertion": "off",
        "typescript/no-unsafe-argument": "off",
        "typescript/no-unsafe-assignment": "off",
        "typescript/no-unsafe-call": "off",
        "typescript/no-unsafe-member-access": "off",
        "typescript/no-unsafe-return": "off",
        "typescript/no-unnecessary-condition": "off",
        "typescript/strict-boolean-expressions": "off",
        "typescript/no-unsafe-type-assertion": "off"
      }
    },
    {
      "files": ["src/arrow-zero-copy.ts"],
      "rules": {
        "typescript/no-unsafe-type-assertion": "off"
      }
    }
  ]
}
