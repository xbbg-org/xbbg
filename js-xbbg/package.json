{
  "name": "@xbbg/core",
  "version": "0.0.0",
  "description": "Bloomberg data API for Node.js powered by Rust xbbg engine",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "errors.js",
    "index.d.ts",
    "index.js",
    "lib",
    "README.md"
  ],
  "scripts": {
    "build": "node ./scripts/build-native.js",
    "stage:native-package": "node ./scripts/stage-native-package.js",
    "stamp:version": "node ./scripts/stamp-version.js",
    "smoke:packaged-install": "node ./scripts/smoke-packaged-install.js",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "node ./test.js",
    "test:live": "node --test --test-timeout=120000 ./test-live.js"
  },
  "keywords": [
    "bloomberg",
    "finance",
    "market-data",
    "arrow"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "apache-arrow": "^21.1.0"
  },
  "optionalDependencies": {
    "@xbbg/core-darwin-arm64": "file:../packages/xbbg-core-darwin-arm64",
    "@xbbg/core-linux-x64": "file:../packages/xbbg-core-linux-x64",
    "@xbbg/core-win32-x64": "file:../packages/xbbg-core-win32-x64"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4"
  },
  "peerDependencies": {
    "nodejs-polars": ">=0.10.0"
  },
  "peerDependenciesMeta": {
    "nodejs-polars": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alpha-xone/xbbg.git",
    "directory": "js-xbbg"
  },
  "engines": {
    "node": ">=18"
  }
}
