{
  "name": "@xbbg/langgraph",
  "version": "0.0.0",
  "description": "LangChain and LangGraph tools for Bloomberg workflows backed by @xbbg/core",
  "keywords": [
    "ai",
    "bloomberg",
    "finance",
    "langchain",
    "langgraph",
    "market-data",
    "tools",
    "xbbg"
  ],
  "homepage": "https://xbbg.org/javascript/",
  "bugs": {
    "url": "https://github.com/xbbg-org/xbbg/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xbbg-org/xbbg.git",
    "directory": "js-xbbg-langgraph"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "npm run lint:ox && npm run lint:eslint",
    "lint:eslint": "eslint .",
    "lint:fix": "oxlint . --fix && eslint --fix .",
    "lint:ox": "oxlint .",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run build",
    "quality": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xbbg/core": "^1.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.2",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-n": "^18.0.1",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "langchain": "^1.4.2",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "@langchain/core": ">=1.0.0 <2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.13.0"
}
